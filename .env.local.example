# FREE AI PROVIDERS (fallback chain: Gemini → Groq → Cloudflare → DeepSeek → HuggingFace)
GEMINI_API_KEY=  # Free: https://aistudio.google.com/apikey — 1500 req/day
GROQ_API_KEY=    # Free: https://console.groq.com/keys — 30 req/min
CF_API_TOKEN=    # Free: https://dash.cloudflare.com → Workers AI — 100k req/day
CF_ACCOUNT_ID=   # Cloudflare Account ID (рядом с токеном)
DEEPSEEK_API_KEY= # Free: https://platform.deepseek.com — generous limits
HF_API_KEY=      # Free: https://huggingface.co/settings/tokens — Inference preset

# Supabase (free tier)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe (for subscriptions)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-key
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_BUSINESS=price_business_monthly
